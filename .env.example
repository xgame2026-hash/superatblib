# Copy this file to .env, then fill these values from the dashboard General Settings page.
# Windows: copy .env.example .env
# macOS/Linux: cp .env.example .env
#
# ETHEREUM_RPC_URL is required for the default dashboard.
# Fill the other RPCs only if you need those chains.
# PRIVATE_KEY is required only when you need to execute transactions.
PRIVATE_KEY=
ETHEREUM_RPC_URL=
BNB_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
POLYGON_RPC_URL=
