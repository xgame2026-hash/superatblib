# Copy this file to .env, then fill these values from the dashboard Settings page.
# Windows: copy .env.example .env
# macOS/Linux: cp .env.example .env
#
# ETHEREUM_RPC_URL is required for the default dashboard.
# Give every user their own SuperMT Node RPC endpoint. Do not share one endpoint
# across users, because request_count/request_limit are tracked by endpoint slug.
# Fill the other RPCs only if you need those chains.
# PRIVATE_KEY is required only when you need to execute transactions.
PRIVATE_KEY=
DASHBOARD_LANGUAGE=zh
FUNDING_MODE=flash_loan
ETHEREUM_RPC_URL=
BNB_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
POLYGON_RPC_URL=

# Optional public liquidation candidate feeds pushed by chain-side servers.
# These feeds are read by the dashboard and do not consume the user's RPC quota.
PUBLIC_LIQUIDATION_FEED_URL=
PUBLIC_LIQUIDATION_FEED_ETHEREUM_URL=
PUBLIC_LIQUIDATION_FEED_BNB_URL=
PUBLIC_LIQUIDATION_FEED_ARBITRUM_URL=
PUBLIC_LIQUIDATION_FEED_POLYGON_URL=

# Optional execution queue bridge. Configure these on the chain-side queue server
# when multiple users share the same public liquidation candidate pool.
LIQUIDATION_QUEUE_API_BASE_URL=
LIQUIDATION_QUEUE_STATUS_URL=
LIQUIDATION_QUEUE_EVENT_URL=
LIQUIDATION_QUEUE_ARBITRUM_API_BASE_URL=https://arb.rpc.supermtnode.io/api/admin/liquidation-queue
LIQUIDATION_QUEUE_BNB_API_BASE_URL=https://bsc.rpc.supermtnode.io/api/admin/liquidation-queue
SUPERMTNODE_LIQUIDATION_QUEUE_ENABLED=

# Optional local queue server. Run with `npm run queue:server`.
LIQUIDATION_QUEUE_HOST=0.0.0.0
LIQUIDATION_QUEUE_PORT=4311
LIQUIDATION_QUEUE_STATE_FILE=.superarb/liquidation-queue.json
LIQUIDATION_QUEUE_MEMBER_TTL_SECONDS=120
LIQUIDATION_QUEUE_LEASE_SECONDS=45
LIQUIDATION_QUEUE_ALLOWED_CHAINS=
LIQUIDATION_QUEUE_ADMIN_TOKEN=

# SuperMT Node usage source for dashboard RPC call counts.
# Use the SUPERMTNODE_APP_TOKEN shown in the endpoint list at https://supermtnode.io/app.
SUPERMTNODE_API_BASE_URL=https://supermtnode.io
SUPERMTNODE_APP_TOKEN=

# Optional dashboard snapshot cache. When Redis is configured, high-churn
# overview/topic data is served from a 5-minute server snapshot instead of
# letting every client hit upstream APIs or RPC-backed providers.
DASHBOARD_OVERVIEW_REDIS_URL=redis://127.0.0.1:6379
DASHBOARD_OVERVIEW_SNAPSHOT_TTL_MS=300000
DASHBOARD_OVERVIEW_STALE_MS=1800000
DASHBOARD_OVERVIEW_SOURCE_TIMEOUT_MS=8000

# Exchange settings are required only when you use exchange arbitrage features.
ARBITRAGE_VENUES=binance,okx,bitget,mexc,gate
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
OKX_API_KEY=
OKX_SECRET_KEY=
BITGET_API_KEY=
BITGET_SECRET_KEY=
MEXC_API_KEY=
MEXC_SECRET_KEY=
GATE_API_KEY=
GATE_SECRET_KEY=
